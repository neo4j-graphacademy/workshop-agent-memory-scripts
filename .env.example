# Copy to .env and fill in. .env is gitignored.

# Neo4j 5.20+ (vector indexes required). Local Docker dev DB or Aura.
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neoneoneo

# Used by EmbeddingConfig (text-embedding-3-small by default) and by the agent's LLM.
OPENAI_API_KEY=sk-...
