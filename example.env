# Your Aura instance - from the downloaded credentials file
NEO4J_URI="neo4j+s://xxxxxxxx.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="..."

# The shared workshop memory instance - your instructor provides these values.
# MVP_SESSION_ID is your own handle in that shared instance - set it to your name.
MVP_NEO4J_URI="neo4j+s://xxxxxxxx.databases.neo4j.io"
MVP_NEO4J_USERNAME="neo4j"
MVP_NEO4J_PASSWORD="..."
MVP_SESSION_ID="your-name"

OPENAI_API_KEY="sk-..."
