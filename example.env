# Copy to .env and fill in your values.

# Your own Neo4j instance - the course knowledge graph the agent searches.
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j

# The shared workshop memory workspace (hosted). Your instructor gives you the
# key on the day - or create a workspace of your own at memory.neo4jlabs.com.
# MVP_SESSION_ID is your own handle in that shared workspace - keep it unique
# to you.
MEMORY_API_KEY=nams_...
MVP_SESSION_ID=your-name

OPENAI_API_KEY=sk-...
